# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:arelis.db

# ── Server ─────────────────────────────────────────────────────────────────────
BIND_ADDR=0.0.0.0:8080
RUST_LOG=arelis_backend=debug,tower_http=debug

# ── Wallet encryption key ──────────────────────────────────────────────────────
# This key encrypts the wallet seed stored in the database.
# It is NOT the seed itself — never put the seed here.
#
# Generate a fresh key once and keep it in your .env:
#   openssl rand -hex 32
#
# If you lose this key and the database, you can still restore from your
# written-down 24-word mnemonic (printed to the log on first run).
WALLET_KEY=replace_with_output_of__openssl_rand_-hex_32

# ── Zcash network ──────────────────────────────────────────────────────────────
# Use 'testnet' while developing; switch to 'mainnet' for production.
ZCASH_NETWORK=testnet

# lightwalletd server — public testnet endpoint from the ECC
LIGHTWALLETD_URL=https://lightwalletd.testnet.electriccoin.co:9067
